 <section class="business-page-hero">
  <div class="container">
    <h1>All Businesses</h1>
    <p>Explore Muslim businesses by category, type, location and date.</p>
  </div>
</section>

  <main class="businesses-page">
  <div class="container businesses-layout">

    <aside class="business-filters">
      <form method="GET" action="/businesses">
        <h3>Filter Businesses</h3>

        <label>Business Type</label>
        <select name="business_type_id">
          <option value="">All Types</option>
          <% types.forEach(function(type) { %>
            <option value="<%= type.id %>" <%= query.business_type_id == type.id ? "selected" : "" %>>
              <%= type.name %>
            </option>
          <% }) %>
        </select>

        <label>Business Category</label>
        <select name="business_category_id">
          <option value="">All Categories</option>
          <% categories.forEach(function(category) { %>
            <option value="<%= category.id %>" <%= query.business_category_id == category.id ? "selected" : "" %>>
              <%= category.name %>
            </option>
          <% }) %>
        </select>

        <label>Location</label>
<input
  type="text"
  name="location"
  id="locationInput"
  value="<%= query.location || '' %>"
  placeholder="Search location"
>
<div class="location-dropdown" id="locationDropdown"></div>
<label>Established Year</label>
<div class="year-slider-box">
  <input
    type="range"
    name="established_year"
    min="1990"
    max="2026"
    value="<%= query.established_year || 1990 %>"
    oninput="document.getElementById('yearValue').innerText = this.value"
  >
  <div class="year-slider-row">
    <span>1990</span>
    <strong id="yearValue"><%= query.established_year || 1990 %></strong>
    <span>2026</span>
  </div>
</div>
        <div class="date-filter-box">
          <label>Date From</label>
          <input type="date" name="date_from" value="<%= query.date_from || '' %>">

          <label>Date To</label>
          <input type="date" name="date_to" value="<%= query.date_to || '' %>">
        </div>

        <% filterFields.forEach(function(field) { %>
          <label><%= field.name %></label>
          <select name="filter_<%= field.id %>">
            <option value="">All <%= field.name %></option>
            <% field.values.forEach(function(filterItem) { %>
              <option value="<%= filterItem.id %>" <%= query["filter_" + field.id] == filterItem.id ? "selected" : "" %>>
                <%= filterItem.value %>
              </option>
            <% }) %>
          </select>
        <% }) %>

        <button type="submit" class="filter-submit">Apply Filters</button>
        <a href="/businesses" class="filter-reset">Reset Filters</a>
      </form>
    </aside>

    <section class="business-results">
      <div class="result-head">
        <h2>All Businesses</h2>
        <div class="count">Showing <%= directories.length %> of <%= totalDirectories %> businesses</div>
      </div>

      <% if (directories.length === 0) { %>
        <div class="empty">No businesses found.</div>
      <% } %>

      <% if (directories.length > 0) { %>
        <section class="directory-grid">
          <% directories.forEach(function(item) { %>
            <article class="directory-card">

              <div class="directory-logo-side">
                

                <div class="logo-wrap">
                  <% if (item.logo_image) { %>
                    <img src="/uploads/logos/<%= item.logo_image %>" alt="<%= item.business_name %> logo">
                  <% } else { %>
                    <span class="no-logo">No Logo</span>
                  <% } %>
                </div>
              </div>

              <div class="directory-main">
                <div class="title-line">
                  <h3><%= item.business_name || "Business Name" %></h3>

                  <span class="rating">
                    <span class="rating-star">☆</span>
                    <%= item.rating || "0.0" %>
                  </span>
                </div>

                <div class="directory-meta">
                  <div class="meta-col">
                    <div class="meta-item">
                      <span class="meta-icon">
                        <svg viewBox="0 0 24 24" fill="none">
                          <path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span><%= item.review_count || 0 %> Reviews</span>
                    </div>

                    <div class="meta-item">
                      <span class="meta-icon">
                        <svg viewBox="0 0 24 24" fill="none">
                          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      </span>
                      <span><%= item.business_category || item.business_type || "Business" %></span>
                    </div>
                  </div>

                  <div class="meta-col">
                    <div class="meta-item">
                      <span class="meta-icon">
                        <svg viewBox="0 0 24 24" fill="none">
                          <path d="M3 11l9-7 9 7v9a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1v-9Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span>Estb. <%= item.established_year || "—" %></span>
                    </div>

                    <div class="meta-item">
                      <span class="meta-icon">
                        <svg viewBox="0 0 24 24" fill="none">
                          <path d="M12 21s7-5.2 7-12a7 7 0 1 0-14 0c0 6.8 7 12 7 12Z" stroke="currentColor" stroke-width="2"/>
                          <path d="M12 11.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" stroke="currentColor" stroke-width="2"/>
                        </svg>
                      </span>
                      <span><%= item.business_location || "Location not available" %></span>
                    </div>
                  </div>
                </div>

                <div class="card-divider"></div>

                <p class="directory-desc">
                  <%= item.description || "This business is listed in the Startup Muslim business directory." %>
                </p>
              </div>

              <% if (item.is_verified == 1) { %>
                <div class="verified-pill">Verified</div>
              <% } %>

            </article>
          <% }) %>
        </section>
      <% } %>

      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a
              class="page-link <%= Number(page) === i ? 'active' : '' %>"
              href="/businesses?<%= new URLSearchParams({...query, page: i}).toString() %>"
            >
              <%= i %>
            </a>
          <% } %>
        </div>
      <% } %>

    </section>
  </div>
</main>
  <script>
    const savedLocations = <%- JSON.stringify(
      (typeof locations !== "undefined" ? locations : [])
        .map(item => item.business_location)
        .filter(Boolean)
    ) %>;

   function toggleAdvanced() {
  const box = document.getElementById("advancedBox");
  const btn = document.querySelector(".advance-btn");

  box.classList.toggle("show");
  btn.classList.toggle("active", box.classList.contains("show"));
}

    document.querySelectorAll(".custom-select").forEach(function(selectBox) {
      const trigger = selectBox.querySelector(".custom-select-trigger");
      const triggerText = trigger.querySelector("span");
      const hiddenInput = selectBox.querySelector("input[type='hidden']");
      const options = selectBox.querySelectorAll(".custom-option");

      const selectedOption = selectBox.querySelector(".custom-option.selected");

      if (selectedOption) {
        triggerText.textContent = selectedOption.textContent.trim();
      }

      trigger.addEventListener("click", function(e) {
        e.stopPropagation();

        document.querySelectorAll(".custom-select").forEach(function(box) {
          if (box !== selectBox) {
            box.classList.remove("active");
          }
        });

        selectBox.classList.toggle("active");
      });

      options.forEach(function(option) {
        option.addEventListener("click", function(e) {
          e.stopPropagation();
          options.forEach(function(item) {
            item.classList.remove("selected");
          });

          option.classList.add("selected");
          hiddenInput.value = option.dataset.value;
          triggerText.textContent = option.textContent.trim();

          selectBox.classList.remove("active");
        });
      });
    });

    const locationInput = document.getElementById("locationInput");
    const locationDropdown = document.getElementById("locationDropdown");

    function renderLocationSuggestions(value) {
      const search = value.trim().toLowerCase();
      locationDropdown.innerHTML = "";

      if (!search) {
        locationDropdown.classList.remove("show");
        return;
      }

      const uniqueLocations = [...new Set(savedLocations)];

      const matchedLocations = uniqueLocations
        .filter(function(location) {
          return location && location.toLowerCase().startsWith(search);
        })
        .slice(0, 12);

      if (matchedLocations.length === 0) {
        locationDropdown.innerHTML = '<div class="location-empty">No matching location found</div>';
        locationDropdown.classList.add("show");
        return;
      }

      matchedLocations.forEach(function(location) {
        const item = document.createElement("div");
        item.className = "location-option";
        item.textContent = location;

        item.addEventListener("click", function() {
          locationInput.value = location;
          locationDropdown.classList.remove("show");
        });

        locationDropdown.appendChild(item);
      });

      locationDropdown.classList.add("show");
    }

    locationInput.addEventListener("input", function() {
      renderLocationSuggestions(this.value);
    });

    locationInput.addEventListener("focus", function() {
      renderLocationSuggestions(this.value);
    });

    document.addEventListener("click", function(e) {
      document.querySelectorAll(".custom-select").forEach(function(box) {
        box.classList.remove("active");
      });

      if (!e.target.closest(".location-field")) {
        locationDropdown.classList.remove("show");
      }
    });
  </script>
