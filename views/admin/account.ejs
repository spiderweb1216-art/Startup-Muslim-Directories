<!DOCTYPE html>
<html>
<head>
  <title>Account Settings</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Jost:wght@500;600;700&display=swap');

    body { margin: 0; background: #f4f6f8; font-family: "DM Sans", sans-serif; color: #111827; }
    .layout { display: flex; min-height: 100vh; }
    .sidebar { width: 250px; background: #101820; color: white; position: fixed; inset: 0 auto 0 0; }
    .brand { padding: 22px; font-family: Jost, sans-serif; font-size: 22px; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .menu { padding: 15px; }
    .menu a { display: block; color: #dfe6ee; text-decoration: none; padding: 13px 14px; border-radius: 8px; margin-bottom: 6px; font-weight: 500; }
    .menu a:hover, .menu a.active { background: #BF1E2D; color: white; }
    .main { margin-left: 250px; width: calc(100% - 250px); }
    .topbar { height: 68px; background: white; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; padding: 0 28px; }
    .topbar h1 { font-family: Jost, sans-serif; margin: 0; font-size: 24px; }
    .content { padding: 28px; }
    .card { max-width: 760px; background: white; border-radius: 14px; padding: 28px; box-shadow: 0 8px 24px rgba(0,0,0,0.05); }
    h2 { font-family: Jost, sans-serif; margin-top: 0; }

    label { display: block; font-weight: 700; margin-bottom: 7px; }
    input {
      width: 100%;
      padding: 13px;
      border: 1px solid #ddd;
      border-radius: 9px;
      margin-bottom: 16px;
      font-family: "DM Sans", sans-serif;
    }

    button {
      background: #BF1E2D;
      color: white;
      border: 0;
      padding: 12px 18px;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
    }

    .note {
      background: #f9fafb;
      border-left: 4px solid #37B649;
      padding: 14px;
      border-radius: 8px;
      margin-bottom: 22px;
      color: #4b5563;
    }

    .success {
      background: rgba(55,182,73,0.1);
      color: #1b7f32;
      padding: 12px 14px;
      border-radius: 8px;
      margin-bottom: 18px;
      font-weight: 700;
    }

    .error {
      background: rgba(191,30,45,0.1);
      color: #BF1E2D;
      padding: 12px 14px;
      border-radius: 8px;
      margin-bottom: 18px;
      font-weight: 700;
    }

    .divider {
      height: 1px;
      background: #e5e7eb;
      margin: 22px 0;
    }
  </style>
</head>
<body>

<div class="layout">
  <%- include("partials/sidebar") %>
  <main class="main">
    <div class="topbar">
      <h1>Account Settings</h1>
    </div>

    <div class="content">
      <div class="card">
        <h2>Your Account</h2>

        <div class="note">
          Role: <strong><%= user.role %></strong>
        </div>

        <% if (success) { %>
          <div class="success"><%= success %></div>
        <% } %>

        <% if (error) { %>
          <div class="error"><%= error %></div>
        <% } %>

        <form method="POST" action="/admin/account/update">
          <label>Name</label>
          <input type="text" name="name" value="<%= user.name %>" required>

          <label>Email</label>
          <input type="email" name="email" value="<%= user.email %>" required>

          <div class="divider"></div>

          <h2>Change Password</h2>

          <label>Current Password</label>
          <input type="password" name="current_password" placeholder="Required only if changing password">

          <label>New Password</label>
          <input type="password" name="new_password" placeholder="New password">

          <label>Confirm New Password</label>
          <input type="password" name="confirm_password" placeholder="Confirm new password">

          <button type="submit">Save Changes</button>
        </form>
      </div>
    </div>
  </main>
</div>

</body>
</html>