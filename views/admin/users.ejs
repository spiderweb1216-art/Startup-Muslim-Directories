<!DOCTYPE html>
<html>
<head>
  <title>Users</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Jost:wght@500;600;700&display=swap');

    body { margin: 0; background: #f4f6f8; font-family: "DM Sans", sans-serif; color: #111827; }
    .layout { display: flex; min-height: 100vh; }
    .sidebar { width: 250px; background: #101820; color: white; position: fixed; inset: 0 auto 0 0; }
    .brand { padding: 22px; font-family: Jost, sans-serif; font-size: 22px; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .menu { padding: 15px; }
    .menu a { display: block; color: #dfe6ee; text-decoration: none; padding: 13px 14px; border-radius: 8px; margin-bottom: 6px; font-weight: 500; }
    .menu a:hover, .menu a.active { background: #BF1E2D; color: white; }
    .main { margin-left: 250px; width: calc(100% - 250px); }
    .topbar { height: 68px; background: white; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; padding: 0 28px; }
    .topbar h1 { font-family: Jost, sans-serif; margin: 0; font-size: 24px; }
    .content { padding: 28px; display: grid; grid-template-columns: 390px 1fr; gap: 24px; }
    .card { background: white; border-radius: 14px; padding: 24px; box-shadow: 0 8px 24px rgba(0,0,0,0.05); }
    h2 { font-family: Jost, sans-serif; margin-top: 0; }

    label { display: block; font-weight: 700; margin-bottom: 7px; }
    input, select {
      width: 100%;
      padding: 13px;
      border: 1px solid #ddd;
      border-radius: 9px;
      margin-bottom: 16px;
      font-family: "DM Sans", sans-serif;
    }

    button {
      background: #BF1E2D;
      color: white;
      border: 0;
      padding: 12px 18px;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
    }

    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 14px; border-bottom: 1px solid #eee; vertical-align: middle; }
    th { background: #fafafa; font-family: Jost, sans-serif; }

    .role {
      display: inline-block;
      background: rgba(55,182,73,0.1);
      color: #37B649;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
    }

    .delete {
      color: #BF1E2D;
      text-decoration: none;
      font-weight: 700;
    }

    .disabled {
      color: #9ca3af;
      font-weight: 700;
    }
  </style>
</head>
<body>

<div class="layout">
  <%- include("partials/sidebar") %>

  <main class="main">
    <div class="topbar">
      <h1>Users</h1>
    </div>

    <div class="content">
      <div class="card">
        <h2>Add New User</h2>

        <form method="POST" action="/admin/users/add">
          <label>Name</label>
          <input type="text" name="name" placeholder="Example: Mudassir" required>

          <label>Email</label>
          <input type="email" name="email" placeholder="user@example.com" required>

          <label>Password</label>
          <input type="password" name="password" placeholder="Enter password" required>

          <label>Role</label>
          <select name="role">
            <option value="admin">Admin</option>
            <option value="editor">Editor</option>
            <option value="super_admin">Super Admin</option>
          </select>

          <button type="submit">Add User</button>
        </form>
      </div>

      <div class="card">
        <h2>All Users</h2>

        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Date</th>
              <th>Action</th>
            </tr>
          </thead>

          <tbody>
            <% users.forEach(function(user) { %>
              <tr>
                <td><strong><%= user.name %></strong></td>
                <td><%= user.email %></td>
                <td><span class="role"><%= user.role %></span></td>
                <td><%= user.created_at %></td>
                <td>
                  <% if (currentUser.id === user.id) { %>
                    <span class="disabled">Current User</span>
                  <% } else { %>
                    <a class="delete" href="/admin/users/delete/<%= user.id %>">Delete</a>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

</body>
</html>