<!DOCTYPE html>
<html>
<head>
  <title>All Directories</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Jost:wght@500;600;700&display=swap');

    body {
      margin: 0;
      background: #f4f6f8;
      font-family: "DM Sans", sans-serif;
      color: #111827;
    }

    .layout {
      display: flex;
      min-height: 100vh;
    }

    .sidebar {
      width: 250px;
      background: #101820;
      color: white;
      position: fixed;
      inset: 0 auto 0 0;
    }

    .brand {
      padding: 22px;
      font-family: Jost, sans-serif;
      font-size: 22px;
      font-weight: 700;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .menu {
      padding: 15px;
    }

    .menu a {
      display: block;
      color: #dfe6ee;
      text-decoration: none;
      padding: 13px 14px;
      border-radius: 8px;
      margin-bottom: 6px;
      font-weight: 500;
    }

    .menu a:hover,
    .menu a.active {
      background: #BF1E2D;
      color: white;
    }

    .main {
      margin-left: 250px;
      width: calc(100% - 250px);
    }

    .topbar {
      height: 68px;
      background: white;
      border-bottom: 1px solid #e5e7eb;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 28px;
    }

    .topbar h1 {
      font-family: Jost, sans-serif;
      margin: 0;
      font-size: 24px;
    }

    .add-btn {
      background: #BF1E2D;
      color: white;
      padding: 11px 16px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
    }

    .content {
      padding: 28px;
    }

    .card {
      background: white;
      border-radius: 14px;
      padding: 24px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.05);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    th,
    td {
      text-align: left;
      padding: 14px;
      border-bottom: 1px solid #eee;
      vertical-align: middle;
      white-space: normal;
      word-break: break-word;
    }

    th {
      background: #fafafa;
      font-family: Jost, sans-serif;
      font-size: 15px;
    }

    .col-logo {
      width: 100px;
    }

    .col-business {
      width: 22%;
    }

    .col-type {
      width: 18%;
    }

    .col-status {
      width: 120px;
    }

    .col-actions {
      width: 170px;
    }

    .logo {
      width: 82px;
      height: 48px;
      object-fit: contain;
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 6px;
    }

    .empty {
      color: #6b7280;
    }

    .badge {
      display: inline-block;
      background: rgba(191,30,45,0.08);
      color: #BF1E2D;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      margin: 2px 0;
    }

    .badge-green {
      background: rgba(55,182,73,0.12);
      color: #37B649;
    }

    .badge-dark {
      background: #f3f4f6;
      color: #111827;
    }

    .action-link {
      font-weight: 700;
      text-decoration: none;
      margin-right: 10px;
    }

    .edit {
      color: #37B649;
    }

    .delete {
      color: #BF1E2D;
    }

    .details-btn {
      background: #101820;
      color: white;
      border: 0;
      padding: 7px 10px;
      border-radius: 7px;
      font-weight: 700;
      cursor: pointer;
      font-family: "DM Sans", sans-serif;
    }

    .details-row {
      display: none;
      background: #fbfbfc;
    }

    .details-box {
      padding: 18px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .detail-item {
      background: white;
      border: 1px solid #eef0f3;
      border-radius: 10px;
      padding: 12px;
    }

    .detail-label {
      display: block;
      color: #6b7280;
      font-size: 13px;
      margin-bottom: 5px;
      font-weight: 700;
    }

    .detail-value {
      font-weight: 600;
    }

    @media (max-width: 900px) {
      .main {
        margin-left: 0;
        width: 100%;
      }

      .sidebar {
        display: none;
      }

      .details-box {
        grid-template-columns: 1fr;
      }

      .col-type {
        display: none;
      }
    }
  </style>
</head>
<body>

<div class="layout">
  <%- include("partials/sidebar") %>

  <main class="main">
    <div class="topbar">
      <h1>All Directories</h1>
      <a class="add-btn" href="/admin/directories/add">Add Directory</a>
    </div>

    <div class="content">
      <div class="card">
        <table>
          <thead>
            <tr>
              <th class="col-logo">Logo</th>
              <th class="col-business">Business</th>
              <th class="col-type">Type / Category</th>
              <th class="col-status">Status</th>
              <th class="col-actions">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (directories.length === 0) { %>
              <tr>
                <td colspan="5" class="empty">No directories added yet.</td>
              </tr>
            <% } %>

            <% directories.forEach(function(item) { %>
              <tr>
                <td>
                  <% if (item.logo_image) { %>
                    <img class="logo" src="/uploads/logos/<%= item.logo_image %>">
                  <% } else { %>
                    <span class="empty">No logo</span>
                  <% } %>
                </td>

                <td>
                  <strong><%= item.business_name %></strong>
                  <br>
                  <small><%= item.business_location || "-" %></small>
                </td>

                <td>
                  <span class="badge"><%= item.business_type || "-" %></span>
                  <br>
                  <span class="badge badge-green"><%= item.business_category || "-" %></span>
                </td>

                <td>
                  <% if (item.status === "draft") { %>
                    <span class="badge badge-dark">Draft</span>
                  <% } else if (item.status === "scheduled") { %>
                    <span class="badge badge-green">Scheduled</span>
                    <br>
                    <small><%= item.scheduled_at || "" %></small>
                  <% } else { %>
                    <span class="badge">Published</span>
                  <% } %>
                </td>

                <td>
                  <a class="action-link edit" href="/admin/directories/edit/<%= item.id %>">Edit</a>

                  <a 
                    class="action-link delete"
                    href="/admin/directories/delete/<%= item.id %>" 
                    onclick="return confirm('Are you sure you want to delete this directory?')"
                  >
                    Delete
                  </a>

                  <button class="details-btn" type="button" onclick="toggleDetails('details-<%= item.id %>')">
                    Details
                  </button>
                </td>
              </tr>

              <tr id="details-<%= item.id %>" class="details-row">
                <td colspan="5">
                  <div class="details-box">

                    <div class="detail-item">
                      <span class="detail-label">Business Name</span>
                      <span class="detail-value"><%= item.business_name || "-" %></span>
                    </div>

                    <div class="detail-item">
                      <span class="detail-label">Business Location</span>
                      <span class="detail-value"><%= item.business_location || "-" %></span>
                    </div>

                    <div class="detail-item">
                      <span class="detail-label">Founder Name</span>
                      <span class="detail-value"><%= item.founder_name || "-" %></span>
                    </div>

                    <div class="detail-item">
                      <span class="detail-label">Business Type</span>
                      <span class="detail-value"><%= item.business_type || "-" %></span>
                    </div>

                    <div class="detail-item">
                      <span class="detail-label">Business Category</span>
                      <span class="detail-value"><%= item.business_category || "-" %></span>
                    </div>

                    <div class="detail-item">
                      <span class="detail-label">Created Date</span>
                      <span class="detail-value"><%= item.created_at || "-" %></span>
                    </div>

                    <% filterFields.forEach(function(field) { %>
                      <div class="detail-item">
                        <span class="detail-label"><%= field.name %></span>
                        <span class="detail-value">
                          <%= filterMap[item.id + "_" + field.id] || "-" %>
                        </span>
                      </div>
                    <% }) %>

                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<script>
  function toggleDetails(id) {
    const row = document.getElementById(id);
    row.style.display = row.style.display === "table-row" ? "none" : "table-row";
  }
</script>

</body>
</html>