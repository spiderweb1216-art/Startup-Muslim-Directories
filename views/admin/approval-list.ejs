<!DOCTYPE html>
<html>
<head>
  <title><%= pageMeta.title %> | Startup Muslim</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/admin-modern.css">
</head>
<body>
<div class="layout">
  <%- include("partials/sidebar") %>
  <main class="main">
    <div class="topbar">
      <div><h1><%= pageMeta.title %></h1><p><%= pageMeta.subtitle %></p></div>
      <div class="toolbar">
        <a class="btn light" href="/admin/approvals">Approvals</a>
        <a class="btn light" href="/admin/not-approved">Not Approved</a>
        <a class="btn" href="/admin/directories/import">Import CSV</a>
        <a class="btn dark" href="/admin/directories/add">Add Directory</a>
      </div>
    </div>

    <div class="content">
      <div class="card table-wrap">
        <table>
          <thead>
            <tr>
              <th style="width:96px;">Logo</th>
              <th style="width:230px;">Business</th>
              <th style="width:190px;">Type / Category</th>
              <th style="width:135px;">Status</th>
              <th style="width:200px;">Owner</th>
              <th style="width:290px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (directories.length === 0) { %>
              <tr><td colspan="6" class="empty">No businesses found in this section.</td></tr>
            <% } %>

            <% directories.forEach(function(item) { %>
              <tr>
                <td><% if (item.logo_image) { %><img class="logo" src="/uploads/logos/<%= item.logo_image %>"><% } else { %><span class="empty">No logo</span><% } %></td>
                <td><strong><%= item.business_name %></strong><br><small><%= item.business_location || '-' %></small></td>
                <td><span class="badge"><%= item.business_type || '-' %></span><br><span class="badge"><%= item.business_category || '-' %></span></td>
                <td><span class="badge <%= item.status || 'published' %>"><%= item.status === 'pending' ? 'Pending' : item.status === 'rejected' ? 'Not Approved' : item.status === 'delete_requested' ? 'Delete Requested' : item.status === 'published' ? 'Published' : item.status || 'Published' %></span><% if (item.admin_note) { %><br><small><%= item.admin_note %></small><% } %></td>
                <td><div class="owner"><strong><%= item.owner_name || 'Admin Added' %></strong><br><%= item.owner_email || 'No owner account' %></div></td>
                <td>
                  <div class="actions">
                    <a class="btn small light" href="/admin/directories/edit/<%= item.id %>">Edit</a>
                    <% if (item.status !== 'published') { %>
                      <form class="mini-form" method="POST" action="/admin/directories/<%= item.id %>/approve"><button class="btn small green" type="submit">Approve</button></form>
                    <% } %>
                    <% if (item.status !== 'rejected') { %>
                      <form class="mini-form" method="POST" action="/admin/directories/<%= item.id %>/reject">
                        <input class="note-input" type="text" name="admin_note" placeholder="Reason if not approved">
                        <button class="btn small dark" type="submit">Not Approve</button>
                      </form>
                    <% } %>
                    <% if (item.status === 'delete_requested') { %>
                      <form class="mini-form" method="POST" action="/admin/directories/<%= item.id %>/cancel-delete"><button class="btn small light" type="submit">Cancel Delete</button></form>
                    <% } %>
                    <form class="mini-form" method="POST" action="/admin/directories/<%= item.id %>/delete" onsubmit="return confirm('Delete this business permanently?')"><button class="btn small danger" type="submit">Delete</button></form>
                    <button class="btn small light" type="button" onclick="toggleDetails('details-<%= item.id %>')">Details</button>
                  </div>
                </td>
              </tr>
              <tr id="details-<%= item.id %>" class="details-row">
                <td colspan="6"><div class="details-box">
                  <div class="detail-item"><span class="detail-label">Business Name</span><span class="detail-value"><%= item.business_name || '-' %></span></div>
                  <div class="detail-item"><span class="detail-label">Location</span><span class="detail-value"><%= item.business_location || '-' %></span></div>
                  <div class="detail-item"><span class="detail-label">Founder</span><span class="detail-value"><%= item.founder_name || '-' %></span></div>
                  <div class="detail-item"><span class="detail-label">Website</span><span class="detail-value"><%= item.website_url || '-' %></span></div>
                  <div class="detail-item"><span class="detail-label">Email</span><span class="detail-value"><%= item.contact_email || '-' %></span></div>
                  <div class="detail-item"><span class="detail-label">Phone</span><span class="detail-value"><%= item.phone_number || '-' %></span></div>
                  <div class="detail-item"><span class="detail-label">Social</span><span class="detail-value"><%= item.social_link || '-' %></span></div>
                  <div class="detail-item"><span class="detail-label">Created</span><span class="detail-value"><%= item.created_at || '-' %></span></div>
                  <% filterFields.forEach(function(field) { %><div class="detail-item"><span class="detail-label"><%= field.name %></span><span class="detail-value"><%= filterMap[item.id + '_' + field.id] || '-' %></span></div><% }) %>
                  <div class="detail-item" style="grid-column:1/-1;"><span class="detail-label">Description</span><span class="detail-value"><%= item.description || '-' %></span></div>
                </div></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<script>function toggleDetails(id){const row=document.getElementById(id);row.style.display=row.style.display==='table-row'?'none':'table-row';}</script>
</body>
</html>
