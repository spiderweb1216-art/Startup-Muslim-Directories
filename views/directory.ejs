<!DOCTYPE html>
<html>
<head>
  <title>Business Directory | Startup Muslim</title>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Jost:wght@500;600;700;800&display=swap');

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      background: #F8F8F8;
      color: #111827;
      font-family: "DM Sans", sans-serif;
    }

    a {
      text-decoration: none;
    }

    .container {
      width: 100%;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* Header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 99999;
      background: #fff;
      border-bottom: 1px solid #ececec;
    }

    .header-inner {
      width: 100%;
      max-width: 1400px;
      min-height: 96px;
      margin: 0 auto;
      padding: 0 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 28px;
      flex-wrap: nowrap;
    }

    .site-logo {
      display: flex;
      align-items: center;
      flex-shrink: 0;
      text-decoration: none;
    }

    .site-logo img {
      width: 190px;
      height: auto;
      display: block;
      object-fit: contain;
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 26px;
      flex: 1;
      flex-wrap: nowrap;
      white-space: nowrap;
    }

    .nav a,
    .nav-dropdown-btn {
      color: #000;
      font-family: "DM Sans", sans-serif;
      font-size: 15px;
      font-weight: 600;
      line-height: 1;
      background: transparent;
      border: 0;
      padding: 0;
      cursor: pointer;
      text-decoration: none;
      transition: 0.2s ease;
    }

    .nav a:hover,
    .nav-dropdown-btn:hover {
      color: #BF1E2D;
    }

    .nav-directories {
      color: #BF1E2D;
    }

    .nav-submit {
      background: #BF1E2D !important;
      color: #fff !important;
      padding: 15px 24px !important;
      border-radius: 6px;
      font-size: 15px !important;
      font-weight: 700 !important;
      flex-shrink: 0;
    }

    .nav-submit:hover {
      background: #9f1824 !important;
      color: #fff !important;
    }

    .nav-dropdown {
      position: relative;
      display: flex;
      align-items: center;
      padding: 18px 0;
      flex-shrink: 0;
    }

    .nav-dropdown::after {
      content: "";
      position: absolute;
      left: -20px;
      right: -20px;
      top: 100%;
      height: 18px;
      background: transparent;
    }

    .nav-dropdown-btn {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .dropdown-icon {
      width: 13px;
      height: 13px;
      transition: transform 0.25s ease;
    }

    .nav-dropdown:hover .dropdown-icon {
      transform: rotate(180deg);
    }

    .nav-dropdown-menu {
      position: absolute;
      top: 100%;
      left: 50%;
      width: 300px;
      background: #fff;
      border: 1px solid #eeeeee;
      border-radius: 14px;
      padding: 12px;
      box-shadow: 0 18px 45px rgba(17, 24, 39, 0.12);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateX(-50%) translateY(10px);
      transition: 0.22s ease;
      z-index: 999999;
    }

    .nav-dropdown:hover .nav-dropdown-menu {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }

    .nav-dropdown-menu::before {
      content: "";
      position: absolute;
      top: -8px;
      left: 50%;
      width: 16px;
      height: 16px;
      background: #fff;
      border-left: 1px solid #eeeeee;
      border-top: 1px solid #eeeeee;
      transform: translateX(-50%) rotate(45deg);
    }

    .nav-dropdown-menu a {
      display: block;
      width: 100%;
      padding: 12px 14px;
      color: #111827 !important;
      font-size: 15px;
      font-weight: 600;
      line-height: 1.3;
      border-radius: 10px;
      background: transparent !important;
    }

    .nav-dropdown-menu a:hover {
      background: #f8f8f8 !important;
      color: #BF1E2D !important;
    }

    /* Hero */
    .hero {
      position: relative;
      z-index: 5;
      padding: 52px 0 30px;
      overflow: visible;
    }

    .hero::before {
      content: "";
      position: absolute;
      width: 440px;
      height: 440px;
      background: radial-gradient(circle, rgba(191,30,45,0.08) 0%, rgba(191,30,45,0) 68%);
      top: -140px;
      left: -120px;
      pointer-events: none;
    }

    .hero::after {
      content: "";
      position: absolute;
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(55,182,73,0.07) 0%, rgba(55,182,73,0) 68%);
      bottom: -150px;
      right: -110px;
      pointer-events: none;
    }

    .hero .container {
      position: relative;
      z-index: 10;
      overflow: visible;
    }

    .hero-box {
      position: relative;
      z-index: 20;
      text-align: center;
      background: linear-gradient(180deg, #ffffff 0%, #fcfcfc 100%);
      border: 1px solid #ededed;
      border-radius: 28px;
      padding: 42px 30px 30px;
      box-shadow: 0 18px 50px rgba(17,24,39,0.06);
      overflow: visible;
      animation: floatIn 0.6s ease;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(191,30,45,0.08);
      color: #BF1E2D;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.3px;
      margin-bottom: 18px;
    }

    .hero h1 {
      max-width: 860px;
      margin: 0 auto;
      font-family: Jost, sans-serif;
      font-size: 42px;
      line-height: 1.12;
      letter-spacing: -1px;
      font-weight: 800;
      color: #111827;
    }

    .hero h1 .accent {
      color: #BF1E2D;
    }

    .hero p {
      max-width: 760px;
      margin: 16px auto 0;
      font-size: 17px;
      line-height: 1.75;
      color: #6b7280;
    }

    .mini-line {
      width: 88px;
      height: 4px;
      border-radius: 999px;
      background: #BF1E2D;
      margin: 22px auto 24px;
    }

    /* Search */
    .search-wrap {
      position: relative;
      z-index: 30;
      max-width: 980px;
      margin: 0 auto;
      overflow: visible;
    }

    .search-box {
      position: relative;
      z-index: 30;
      background: #fff;
      border: 1px solid #ededed;
      border-radius: 18px;
      padding: 10px;
      box-shadow: 0 12px 30px rgba(17,24,39,0.05);
      overflow: visible;
    }

    .search-grid {
      position: relative;
      z-index: 30;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 70px;
      gap: 10px;
      align-items: center;
      overflow: visible;
    }

    .custom-select,
    .location-field {
      position: relative;
      z-index: 40;
    }

    .custom-select.active {
      z-index: 99999;
    }

    .custom-select-trigger,
    .location-field input {
      width: 100%;
      height: 54px;
      border: 1px solid #ececec;
      border-radius: 14px;
      padding: 0 16px;
      background: #fff;
      color: #111827;
      font-size: 15px;
      font-family: "DM Sans", sans-serif;
      outline: none;
      transition: 0.2s ease;
    }

    .custom-select-trigger {
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      text-align: left;
    }

    .custom-select-trigger:hover,
    .location-field input:hover {
      border-color: rgba(191,30,45,0.45);
    }

    .custom-select.active .custom-select-trigger,
    .location-field input:focus {
      border-color: #BF1E2D;
      box-shadow: 0 0 0 4px rgba(191,30,45,0.08);
    }

    .select-dropdown-icon,
    .advance-icon {
      color: #BF1E2D;
      width: 14px;
      height: 14px;
      flex-shrink: 0;
      transition: transform 0.25s ease;
    }

    .custom-select.active .select-dropdown-icon,
    .advance-btn.active .advance-icon {
      transform: rotate(180deg);
    }

    .custom-options,
    .location-dropdown {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      z-index: 999999;
      background: #fff;
      border: 1px solid rgba(191, 30, 45, 0.16);
      border-radius: 16px;
      padding: 10px;
      box-shadow: 0 22px 55px rgba(17, 24, 39, 0.16);
      display: none;
      max-height: 260px;
      overflow-y: auto;
      animation: dropdownFade 0.18s ease;
    }

    .custom-options::before,
    .location-dropdown::before {
      content: "";
      position: absolute;
      top: -7px;
      left: 28px;
      width: 14px;
      height: 14px;
      background: #fff;
      border-left: 1px solid rgba(191, 30, 45, 0.16);
      border-top: 1px solid rgba(191, 30, 45, 0.16);
      transform: rotate(45deg);
    }

    .custom-select.active .custom-options,
    .location-dropdown.show {
      display: block;
    }

    .custom-option,
    .location-option {
      position: relative;
      z-index: 2;
      padding: 13px 14px;
      border-radius: 11px;
      font-size: 15px;
      font-weight: 600;
      color: #1f2937;
      cursor: pointer;
      transition: 0.18s ease;
      text-align: left;
      background: transparent;
    }

    .custom-option:hover,
    .custom-option.selected,
    .location-option:hover {
      background: rgba(191,30,45,0.08);
      color: #BF1E2D;
    }

    .location-empty {
      position: relative;
      z-index: 2;
      padding: 12px 13px;
      color: #9ca3af;
      font-size: 14px;
      font-weight: 600;
      text-align: left;
    }

    .search-btn {
      height: 54px;
      border: 0;
      border-radius: 14px;
      background: #BF1E2D;
      color: white;
      font-size: 22px;
      cursor: pointer;
      transition: 0.25s ease;
      box-shadow: 0 10px 25px rgba(191,30,45,0.20);
    }

    .search-btn:hover {
      background: #a31824;
      transform: translateY(-1px);
    }

    .search-bottom {
      margin-top: 18px;
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
      align-items: center;
    }

    .advance-btn {
      border: 0;
      background: transparent;
      color: #BF1E2D;
      font-family: Jost, sans-serif;
      font-size: 17px;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 0;
    }

    .reset-link {
      color: #6b7280;
      font-size: 14px;
      font-weight: 600;
    }

    .reset-link:hover {
      color: #BF1E2D;
    }

    /* Advanced */
    .advanced-box {
      display: none;
      position: relative;
      z-index: 25;
      max-width: 980px;
      margin: 18px auto 0;
      background: #fff;
      border: 1px solid #ececec;
      border-radius: 20px;
      padding: 22px;
      box-shadow: 0 12px 30px rgba(17,24,39,0.05);
      animation: fadeUp 0.25s ease;
      overflow: visible;
    }

    .advanced-box.show {
      display: block;
    }

    .advanced-title {
      margin: 0 0 16px;
      font-family: Jost, sans-serif;
      font-size: 20px;
      font-weight: 800;
      color: #111827;
      text-align: center;
    }

    .advanced-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      overflow: visible;
    }

    .advanced-item {
      position: relative;
      overflow: visible;
    }

    .advanced-item label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: 700;
      color: #374151;
      text-align: left;
    }

    .advanced-item input {
      width: 100%;
      height: 54px;
      border: 1px solid #ececec;
      border-radius: 14px;
      padding: 0 16px;
      background: #fff;
      color: #111827;
      font-family: "DM Sans", sans-serif;
      font-size: 15px;
      outline: none;
      transition: 0.2s ease;
    }

    .advanced-item input:focus {
      border-color: #BF1E2D;
      box-shadow: 0 0 0 4px rgba(191,30,45,0.08);
    }

    /* Results */
    .results-wrap {
      position: relative;
      z-index: 1;
      padding: 24px 0 60px;
    }

    .result-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .result-head h2 {
      margin: 0;
      font-family: Jost, sans-serif;
      font-size: 30px;
      font-weight: 800;
      color: #111827;
    }

    .count {
      color: #6b7280;
      font-size: 15px;
      font-weight: 600;
    }

    .empty {
      background: #fff;
      border: 1px solid #ececec;
      border-radius: 16px;
      padding: 30px;
      color: #6b7280;
      font-size: 16px;
      font-weight: 600;
      text-align: center;
    }

    .directory-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .directory-card {
      position: relative;
      display: grid;
      grid-template-columns: 135px minmax(0, 1fr);
      gap: 18px;
      align-items: start;
      background: #fff;
      border: 1px solid #f1f1f1;
      border-radius: 12px;
      padding: 22px;
      min-height: 230px;
      box-shadow: 0 8px 24px rgba(17, 24, 39, 0.06);
      transition: 0.25s ease;
      overflow: hidden;
    }

    .directory-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 34px rgba(17, 24, 39, 0.09);
    }

    .directory-logo-side {
      position: relative;
      min-height: 150px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .logo-wrap {
      width: 125px;
      height: 120px;
      background: transparent;
      border: 0;
      box-shadow: none;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: visible;
    }

    .logo-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 0;
    }

    .no-logo {
      width: 115px;
      height: 100px;
      border-radius: 14px;
      background: #f7f7f7;
      color: #9ca3af;
      font-size: 13px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .logo-bookmark {
      position: absolute;
      top: 0;
      right: 0;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: #10b82f;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 19px;
      line-height: 1;
      box-shadow: 0 6px 14px rgba(16, 184, 47, 0.22);
      z-index: 2;
    }

    .directory-main {
      min-width: 0;
      padding-top: 2px;
    }

    .title-line {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 14px;
      padding-right: 92px;
    }

    .directory-card h3 {
      margin: 0;
      font-family: Jost, sans-serif;
      font-size: 20px;
      font-weight: 800;
      color: #151922;
      line-height: 1.25;
    }

    .rating {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: #808894;
      font-size: 15px;
      font-weight: 700;
    }

    .rating-star {
      font-size: 20px;
      color: #98a1ad;
      line-height: 1;
    }

    .directory-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px 18px;
      margin-bottom: 18px;
    }

    .meta-col {
      display: grid;
      gap: 13px;
    }

    .meta-item {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #606975;
      font-size: 14px;
      font-weight: 500;
      line-height: 1.35;
    }

    .meta-icon {
      width: 20px;
      color: #6f7782;
      font-size: 18px;
      line-height: 1;
      text-align: center;
      flex: 0 0 20px;
    }

    .card-divider {
      height: 1px;
      background: #e4e6ea;
      margin: 0 0 14px;
    }

    .directory-desc {
      margin: 0;
      color: #5d6672;
      font-size: 14px;
      line-height: 1.65;
    }

    .verified-pill {
      position: absolute;
      top: 20px;
      right: 20px;
      background: #e9faef;
      color: #10a83a;
      border-radius: 999px;
      padding: 7px 15px;
      font-size: 15px;
      font-weight: 500;
      line-height: 1;
      white-space: nowrap;
    }

    .pagination {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 26px;
      flex-wrap: wrap;
    }

    .page-link {
      min-width: 38px;
      height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #ececec;
      border-radius: 10px;
      background: #fff;
      color: #374151;
      font-weight: 700;
    }

    .page-link.active,
    .page-link:hover {
      background: #BF1E2D;
      color: #fff;
      border-color: #BF1E2D;
    }

    @keyframes floatIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes dropdownFade {
      from {
        opacity: 0;
        transform: translateY(6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 1180px) {
      .header-inner {
        gap: 20px;
      }

      .nav {
        gap: 18px;
      }

      .site-logo img {
        width: 165px;
      }

      .nav a,
      .nav-dropdown-btn,
      .nav-submit {
        font-size: 14px !important;
      }

      .nav-submit {
        padding: 13px 18px !important;
      }
    }

    @media (max-width: 992px) {
      .header-inner {
        flex-wrap: wrap;
        justify-content: center;
        padding: 18px 20px;
      }

      .nav {
        width: 100%;
        justify-content: center;
        flex-wrap: wrap;
      }

      .search-grid {
        grid-template-columns: 1fr 1fr;
      }

      .search-btn {
        grid-column: span 2;
      }

      .advanced-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .directory-grid {
        grid-template-columns: 1fr;
      }

      .directory-card {
        grid-template-columns: 180px minmax(0, 1fr);
      }

      .logo-wrap {
        width: 155px;
        height: 135px;
      }
    }

    @media (max-width: 768px) {
      .hero {
        padding-top: 32px;
      }

      .hero-box {
        padding: 32px 18px 24px;
        border-radius: 22px;
      }

      .hero h1 {
        font-size: 32px;
      }

      .hero p {
        font-size: 15px;
      }

      .search-grid,
      .advanced-grid {
        grid-template-columns: 1fr;
      }

      .search-btn {
        grid-column: auto;
      }

      .directory-card {
        grid-template-columns: 1fr;
        padding: 24px;
        gap: 18px;
      }

      .directory-logo-side {
        justify-content: flex-start;
        min-height: auto;
      }

      .logo-wrap {
        width: 150px;
        height: 120px;
      }

      .logo-bookmark {
        left: 130px;
        right: auto;
      }

      .directory-meta {
        grid-template-columns: 1fr;
        gap: 14px;
      }

      .title-line {
        padding-right: 0;
      }

      .verified-pill {
        top: 20px;
        right: 20px;
        font-size: 15px;
      }

      .result-head {
        display: block;
      }

      .count {
        margin-top: 6px;
      }
    }
    .logo-wrap {
  width: 160px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.logo-wrap img {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
}
.meta-icon {
  width: 22px;
  height: 22px;
  color: #6f7782;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 22px;
}

.meta-icon svg {
  width: 18px;
  height: 18px;
  display: block;
}
.logo-bookmark {
  position: absolute;
  top: 0;
  right: 0;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: #10b82f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 18px rgba(16, 184, 47, 0.24);
  z-index: 2;
}

.logo-bookmark svg {
  width: 18px;
  height: 18px;
  display: block;
}
.see-more-wrap {
  text-align: center;
  margin-top: 34px;
}

.see-more-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #BF1E2D;
  color: #fff;
  padding: 15px 28px;
  border-radius: 10px;
  font-weight: 700;
  transition: 0.25s ease;
}

.see-more-btn:hover {
  background: #9f1824;
  transform: translateY(-2px);
}
/* 3 Step Listing Process */
.listing-process-section {
  padding: 76px 0 86px;
  background: #F8F8F8;
}

.listing-process-inner {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
}

.process-heading {
  max-width: 760px;
  margin: 0 auto 42px;
  text-align: center;
}

.process-eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 16px;
  margin-bottom: 16px;
  border-radius: 999px;
  background: rgba(191, 30, 45, 0.08);
  color: #BF1E2D;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.4px;
}

.process-heading h2 {
  margin: 0;
  font-family: Jost, sans-serif;
  font-size: 42px;
  line-height: 1.12;
  font-weight: 800;
  color: #111827;
  letter-spacing: -0.8px;
}

.process-heading p {
  max-width: 680px;
  margin: 16px auto 0;
  color: #6b7280;
  font-size: 17px;
  line-height: 1.75;
}

.process-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 24px;
}

.process-card {
  position: relative;
  background: #fff;
  border: 1px solid #eeeeee;
  border-radius: 24px;
  padding: 34px 28px 30px;
  box-shadow: 0 16px 45px rgba(17, 24, 39, 0.06);
  transition: 0.25s ease;
  overflow: hidden;
}

.process-card::before {
  content: "";
  position: absolute;
  width: 160px;
  height: 160px;
  right: -70px;
  top: -70px;
  background: radial-gradient(circle, rgba(191, 30, 45, 0.10), rgba(191, 30, 45, 0));
  pointer-events: none;
}

.process-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 22px 60px rgba(17, 24, 39, 0.09);
  border-color: rgba(191, 30, 45, 0.22);
}

.process-number {
  position: absolute;
  top: 22px;
  right: 24px;
  font-family: Jost, sans-serif;
  font-size: 36px;
  font-weight: 800;
  color: rgba(191, 30, 45, 0.10);
  line-height: 1;
}

.process-icon {
  width: 58px;
  height: 58px;
  border-radius: 18px;
  background: rgba(191, 30, 45, 0.08);
  color: #BF1E2D;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
}

.process-icon svg {
  width: 28px;
  height: 28px;
  display: block;
}

.process-card h3 {
  margin: 0 0 12px;
  font-family: Jost, sans-serif;
  font-size: 23px;
  line-height: 1.25;
  font-weight: 800;
  color: #111827;
}

.process-card p {
  margin: 0;
  color: #606975;
  font-size: 15px;
  line-height: 1.75;
}

.process-cta {
  margin-top: 38px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.process-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
  padding: 0 30px;
  border-radius: 12px;
  background: #BF1E2D;
  color: #fff;
  font-size: 15px;
  font-weight: 800;
  box-shadow: 0 12px 28px rgba(191, 30, 45, 0.22);
  transition: 0.25s ease;
}

.process-btn:hover {
  background: #9f1824;
  color: #fff;
  transform: translateY(-2px);
}

.process-cta span {
  color: #6b7280;
  font-size: 14px;
  font-weight: 600;
}

@media (max-width: 992px) {
  .process-grid {
    grid-template-columns: 1fr;
  }

  .process-heading h2 {
    font-size: 34px;
  }

  .listing-process-section {
    padding: 58px 0 66px;
  }
}
/* Red Directory Stats Section */
.directory-stats-section {
  position: relative;
  overflow: hidden;
  padding: 84px 0;
  background: linear-gradient(135deg, #BF1E2D 0%, #991724 100%);
  color: #fff;
}

.stats-bg-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.12;
  background-image:
    radial-gradient(circle at 20% 20%, rgba(255,255,255,0.65) 0 2px, transparent 2px),
    radial-gradient(circle at 80% 30%, rgba(255,255,255,0.45) 0 2px, transparent 2px),
    linear-gradient(45deg, transparent 48%, rgba(255,255,255,0.35) 49%, rgba(255,255,255,0.35) 51%, transparent 52%);
  background-size: 42px 42px, 56px 56px, 34px 34px;
  pointer-events: none;
}

.directory-stats-section::before {
  content: "";
  position: absolute;
  width: 420px;
  height: 420px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  top: -180px;
  left: -120px;
}

.directory-stats-section::after {
  content: "";
  position: absolute;
  width: 360px;
  height: 360px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.10);
  right: -120px;
  bottom: -170px;
}

.stats-inner {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 46px;
  align-items: center;
}

.stats-eyebrow {
  display: inline-flex;
  align-items: center;
  padding: 8px 16px;
  margin-bottom: 18px;
  border-radius: 999px;
  background: rgba(255,255,255,0.14);
  color: #fff;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.4px;
}

.stats-content h2 {
  margin: 0;
  max-width: 620px;
  font-family: Jost, sans-serif;
  font-size: 42px;
  line-height: 1.12;
  font-weight: 800;
  letter-spacing: -0.8px;
  color: #fff;
}

.stats-content p {
  max-width: 570px;
  margin: 16px 0 0;
  color: rgba(255,255,255,0.82);
  font-size: 17px;
  line-height: 1.75;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.stats-card {
